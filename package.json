{
  "name": "pokedex-thailand",
  "version": "1.0.0",
  "private": true,
  "description": "Pokedex Thailand Ultimate Edition - The most comprehensive Pokemon encyclopedia in Thailand",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
